{
  "name": "stratabracket",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "npm run build --workspace worker && npm run build --workspace frontend",
    "dev": "npm run dev --workspace frontend",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "scripts/test-integration.sh",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "typecheck": "tsc --build --pretty false",
    "verify": "scripts/verify.sh"
  },
  "workspaces": [
    "worker",
    "frontend"
  ],
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260529.0",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
